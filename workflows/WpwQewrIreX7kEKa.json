            }
          ]
        }
      }
    },
    {
      "id": "5cc510ff-036a-4622-9020-92454621590e",
      "name": "Llamar Orquestador",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        700,
        400
      ],
      "parameters": {
        "method": "POST",
        "url": "http://localhost:5678/webhook/pedidos-orchestrator",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"drogueria_code\": \"DROCERCA\",\n  \"metodo_envio\": \"FTP\",\n  \"pedido_id\": {{ $json.PropuestaID }}\n}"
      }
    },
    {
      "id": "bec48aa2-9c0b-418d-90fc-93c2cc1757aa",
      "name": "Avisar Éxito (HTTP)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        900,
        400
      ],
      "parameters": {
        "method": "POST",
        "url": "https://api.telegram.org/bot8645482282:AAGqzeZPtgSJYTZMTiRYDX9uHvf7cr6DzEw/editMessageText",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({\n        chat_id: $json.chat_id,\n        message_id: $json.message_id,\n        text: \"✅ *Pedido #\" + $json.PropuestaID + \" Enviado Exitosamente por FTP al Orquestador.*\",\n        parse_mode: \"markdown\"\n      }) }}"
      }
    }
