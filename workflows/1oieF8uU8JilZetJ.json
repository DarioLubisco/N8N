    {
      "id": "8196fc45-9a97-4e93-af3d-3c8fd6ff27fc",
      "name": "¿Hay Huesos?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        500,
        300
      ],
      "parameters": {
        "conditions": {
