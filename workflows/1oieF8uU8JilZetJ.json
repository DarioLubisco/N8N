      ],
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT NoSolicitadoID, PedidoID, CodProv, CodigoProducto, DescripcionProducto, CantidadRecibida \n              FROM Procurement.BackorderRecepcionesNoSolicitadas \n              WHERE EstadoDecision = 'PENDIENTE_DECISION';"
      },
