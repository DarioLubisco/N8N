    {
      "id": "d5fa705b-3436-4b7d-8313-5f9f9bbaffc4",
      "name": "Formatear Alerta Telegram",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        700,
        200
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "language": "javaScript",
        "jsCode": "const items = $input.all();\nlet msg = \"🚨 *Alerta de Huesos (No Solicitados)*\\n\\n\";\nmsg += \"Se detectaron los siguientes productos ingresados sin orden de pedido:\\n\";\n\nitems.forEach(item => {\n  const d = item.json;\n  msg += `\\n📦 *Prov:* ${d.CodProv} | *Ped:* ${d.PedidoID}\\n`;\n  msg += `   - ${d.DescripcionProducto} (x${d.CantidadRecibida})\\n`;\n});\n\nmsg += \"\\nPor favor, ingresa a Synapse para [Aceptar] o generar [Devolución].\";\n\nreturn [{ json: { text: msg } }];"
      }
    },
