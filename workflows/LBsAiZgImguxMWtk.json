      "parameters": {
        "mode": "runOnceForAllItems",
        "language": "javaScript",
        "jsCode": "const data = $('Recibir Pedido Fallback').first().json;\nconst items = data.items || [];\nreturn items.map(i => ({\n  json: {\n    \"Codigo de Producto\": i.codigo_producto,\n    \"Descripcion\": i.descripcion,\n    \"Cantidad\": i.cantidad,\n    \"Precio\": i.precio_unitario || 0\n  }\n}));"
      }
