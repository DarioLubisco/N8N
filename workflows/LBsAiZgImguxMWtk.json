        "jsCode": "// Aquí iría el nodo de Twilio, WhatsApp Business API, o Email (SMTP)\n// Por ahora simulamos éxito\nreturn [{ json: { success: true, method: $('Recibir Pedido Fallback').first().json.metodo_envio } }];"
