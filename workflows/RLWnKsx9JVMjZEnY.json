    {
      "parameters": {
        "jsCode": "const triggerData = $('Recibir Pedido Dronena').first().json;\nconst corrData = $('Obtener Correlativo Nena').first().json;\n\nconst items = triggerData.items || [];\nconst codCliente = triggerData.cod_cliente || 'C344';\nconst carpeta = triggerData.carpeta_pedidos || '/Maracay/C344/';\nconst correlativo = corrData.correlativo || 1;\n\n// Formato de Pedido para Dronena\nconst fileName = 'pedido_dronena_' + correlativo + '.txt';\n\nconst lines = items.map(item => {\n  return `${item.codigo_producto};${item.cantidad}`;\n});\nconst fileContent = lines.join('\\n');\n\nreturn [{\n  json: {\n    fileName,\n    fileContent,\n    fullPath: `${carpeta}${fileName}`,\n    correlativo,\n    drogueria_code: 'DRONENA'\n  }\n}];"
      },
