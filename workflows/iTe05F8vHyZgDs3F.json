      "typeVersion": 1,
      "position": [
        1250,
        100
      ],
      "parameters": {
        "command": "python3 /opt/scripts/droguerias/mastranto.py --sucursal CENTRO --tabla MastrantoC_Inventario"
      },
      "credentials": {
        "sshPassword": {
          "id": "q9XQyJD7Uu17tWSl",
