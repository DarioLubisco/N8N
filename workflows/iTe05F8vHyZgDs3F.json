    },
    {
      "id": "e7a8d366-28cb-4d23-a3e0-e61ccdf10893",
      "name": "⚙️ Mapear Switches",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        850,
        304
      ],
      "parameters": {
        "jsCode": "\nconst sqlRows = $input.all();\nconst textData = $('📄 Convertir a Texto').item.json;\n\nlet centroActivo = true;\nlet barinasActivo = true;\n\nfor (const row of sqlRows) {\n  if (row.json.Sucursal === 'CENTRO') centroActivo = row.json.Activo === true;\n  if (row.json.Sucursal === 'BARINAS') barinasActivo = row.json.Activo === true;\n}\n\nreturn [{\n  json: {\n    habilitar_centro: centroActivo,\n    habilitar_barinas: barinasActivo,\n    inventario_txt: textData.inventario_txt\n  }\n}];\n"
      }
    },
    {
      "id": "7ba21129-6b32-41db-a393-c97cd4a3dcb9",
      "name": "¿Activar Centro?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.3,
      "position": [
        1050,
        200
      ],
      "parameters": {
        "conditions": {
          "conditions": [
            {
              "leftValue": "={{ $json.habilitar_centro }}",
              "operator": {
                "type": "boolean",
                "operation": "true"
              }
            }
          ]
        }
      }
    },
    {
      "id": "eeaab7e1-f46e-4cbd-b7ec-e7957936d415",
      "name": "🐍 SSH — Parsear Mastranto Centro",
