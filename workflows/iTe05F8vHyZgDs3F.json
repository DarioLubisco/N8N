        }
      }
    },
    {
      "id": "77b8007e-fd3b-45f7-8966-fd7be4c13cdb",
      "name": "✅ ¿Éxito Centro?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.3,
      "position": [
        1450,
        100
      ],
      "parameters": {
        "conditions": {
          "conditions": [
            {
              "leftValue": "={{ $json.stdout }}",
              "operator": {
                "type": "string",
                "operation": "contains"
              },
              "rightValue": "OK"
            }
          ]
        },
        "options": {
          "ignoreCase": true
        }
      }
    },
    {
      "id": "ee3fb298-c5b5-4242-b168-9df6c4ef737a",
      "name": "📊 Formatear Resultado",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1700,
        300
      ],
      "parameters": {
        "jsCode": "\nconst outputCentro = $('🐍 SSH — Parsear Mastranto Centro').item?.json?.stdout || '';\nconst outputBarinas = $('🐍 SSH — Parsear Mastranto Barinas').item?.json?.stdout || '';\n\nconst matchCentro = outputCentro.match(/ROWS:(\\d+)/);\nconst matchBarinas = outputBarinas.match(/ROWS:(\\d+)/);\n\nconst rowsC = matchCentro ? parseInt(matchCentro[1]) : 0;\nconst rowsB = matchBarinas ? parseInt(matchBarinas[1]) : 0;\n\nreturn [{\n  json: {\n    status: 'success',\n    proveedor: 'Mastranto',\n    archivo: 'inventario.txt',\n    registros_centro: rowsC,\n    registros_barinas: rowsB,\n    timestamp: new Date().toISOString()\n  }\n}];\n"
      }
    },
    {
      "id": "00761762-f89d-44f2-a3c2-5e53d4ed849d",
      "name": "❌ Preparar Error",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1650,
        600
      ],
      "parameters": {
        "jsCode": "\nconst stderr = $input.first().json.stderr || 'Sin detalles';\nconst stdout = $input.first().json.stdout || '';\n\nreturn [{\n  json: {\n    status: 'error',\n    proveedor: 'Mastranto',\n    error_detail: stderr || stdout,\n    timestamp: new Date().toISOString()\n  }\n}];\n"
      }
    },
    {
      "id": "08c07307-2ea2-4c94-b975-a8e4570b5798",
