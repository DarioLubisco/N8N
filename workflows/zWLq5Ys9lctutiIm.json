    {
      "parameters": {
        "jsCode": "\ntry {\n  let raw = $input.first().json.text;\n  if(raw.startsWith(\"```json\")) {\n    raw = raw.replace(/```json/g, \"\").replace(/```/g, \"\").trim();\n  }\n  let data = JSON.parse(raw);\n  \n  // Agregar ID original del archivo por si lo necesitamos después\n  data.fileId = $('1. Al Agregar Fattura').item.json.id;\n  \n  return [ { json: data } ];\n} catch (e) {\n  throw new Error(\"Gemini returned invalid JSON: \" + e.message);\n}\n"
      },
