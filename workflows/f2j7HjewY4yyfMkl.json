        "jsCode": "\n        let max_reintentos = 3;\n        let espera = 5;\n        if ($input.all()[0].json.Max_Reintentos) {\n          max_reintentos = $input.all()[0].json.Max_Reintentos;\n          espera = $input.all()[0].json.Minutos_Espera_Reintento;\n        }\n        return [{ json: { Max_Reintentos: max_reintentos, Minutos_Espera_Reintento: espera } }];\n      "
