      "name": "Recibir Proveedor",
      "type": "n8n-nodes-base.executeWorkflowTrigger",
      "typeVersion": 1,
      "position": [
        -48,
        -64
      ]
    },
    {
      "parameters": {
        "jsCode": "\n        for (const item of $input.all()) {\n          const nombre = item.json.nombre;\n          let cmd = \"\";\n          \n          if (nombre === \"NENA\") {\n            cmd = \"python3 /opt/scripts/droguerias/nena.py\";\n          } else if (nombre === \"DROCERCA\") {\n            cmd = \"python3 /opt/scripts/droguerias/drocerca.py\";\n          } else if (nombre === \"Gama\") {\n            cmd = \"python3 /opt/scripts/droguerias/generic_inventario.py --proveedor GAMA --tabla Gama_Inventario --cols 10 --ftp-host ftp.electrodomotica.com.ve --ftp-user GAMA@electrodomotica.com.ve --ftp-pass SK1OiDJaTKtT --ftp-path /Inventario/INVENTARIO.Txt\";\n          } else if (nombre === \"Biogenetica\") {\n            cmd = \"python3 /opt/scripts/droguerias/generic_inventario.py --proveedor BIOGENETICA --tabla Biogenetica_Inventario --cols 8 --ftp-host 46.202.182.119 --ftp-user u381534864.clientesdrogueriabiogenetica --ftp-pass 'D=Qb13vi.Wmh' --ftp-path /Existencia/inventario.txt\";\n          } else {\n            cmd = \"echo 'Proveedor generico \" + nombre + \" sin configuracion FTP'\";\n          }\n          item.json.command = cmd;\n        }\n        return $input.all();\n      "
      },
      "id": "317f24f8-00e1-41f1-a0c0-5979627a4476",
      "name": "Resolver Comando",
      "type": "n8n-nodes-base.code",
