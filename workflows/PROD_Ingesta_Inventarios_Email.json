{
  "name": "[PROD] Ingesta_Inventarios_Email",
  "nodes": [
    {
      "parameters": {
        "pollTimes": {
          "item": [
            {
              "mode": "everyMinute"
            }
          ]
        },
        "filters": {
          "hasAttachment": true
        },
        "format": "resolved",
        "downloadAttachments": true,
        "options": {}
      },
      "name": "Gmail Trigger",
      "type": "n8n-nodes-base.gmailTrigger",
      "typeVersion": 1,
      "position": [0, 0]
    },
    {
      "parameters": {
        "dataPropertyName": "attachment_0",
        "fileName": "=/tmp/attachments/{{ $binary?.attachment_0?.fileName || 'temp.xlsx' }}",
        "options": {
          "append": false
        }
      },
      "name": "Save Attachment to Disk",
      "type": "n8n-nodes-base.writeBinaryFile",
      "typeVersion": 1,
      "position": [250, 0]
    },
    {
      "parameters": {
        "command": "=python3 /opt/scripts/droguerias/email_parser.py --legacy-mode --file \"/tmp/attachments/{{ $binary?.attachment_0?.fileName || 'temp.xlsx' }}\""
      },
      "name": "Execute Python Script (SSH)",
      "type": "n8n-nodes-base.ssh",
      "typeVersion": 1,
      "position": [500, 0]
    }
  ],
  "connections": {
    "Gmail Trigger": {
      "main": [[{"node": "Save Attachment to Disk", "type": "main", "index": 0}]]
    },
    "Save Attachment to Disk": {
      "main": [[{"node": "Execute Python Script (SSH)", "type": "main", "index": 0}]]
    }
  },
  "settings": {
    "errorWorkflow": "zLtMDgsc7OSXyXrp"
  }
}
