        512,
        304
      ],
      "credentials": {
        "microsoftSql": {
          "id": "oCKBzGZBl1xETeZa",
          "name": "[PROD] MSSQL - Saint Enterprise"
        }
      }
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "\n        -- 2. Take a snapshot of the live market view and save to Mercado_Historico\n        INSERT INTO Analitica.Mercado_Historico (CodBarras, Fecha, PrecioPromedio, PrecioMinimo, PrecioMaximo, PrecioStdDev, PrecioMediana, StockTotalMercado, ProveedoresConStock, DisponibilidadPorcentual)\n        SELECT \n            CodBarras,\n            CAST(GETDATE() AS DATE),\n            PrecioPromedio,\n            PrecioMinimo,\n            PrecioMaximo,\n            PrecioStdDev,\n            PrecioPromedio, \n            StockTotalMercado,\n            ProveedoresConStock,\n            DisponibilidadPorcentual\n        FROM Analitica.Mercado_Vivo;\n      "
      },
      "id": "1516398b-c6c0-495a-9384-302cda97acf3",
