    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "\n        -- 1. Insert daily averages per supplier into Historico_Diario\n        INSERT INTO Proveedores.Historico_Diario (CodBarras, Proveedor, Fecha, PrecioPromedio, StockPromedio)\n        SELECT \n            CodBarras,\n            Proveedor,\n            CAST(FechaCarga AS DATE) as Fecha,\n            AVG(Precio) as PrecioPromedio,\n            AVG(Stock) as StockPromedio\n        FROM Proveedores.Transacciones_Diarias\n        GROUP BY CodBarras, Proveedor, CAST(FechaCarga AS DATE);\n      "
      },
      "id": "37327b2d-635b-45b9-ab84-131e20fd8f8c",
      "name": "Calculate Provider Averages",
      "type": "n8n-nodes-base.microsoftSql",
      "typeVersion": 1.1,
