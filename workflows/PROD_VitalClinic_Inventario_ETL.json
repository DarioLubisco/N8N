{
  "name": "Ingesta: VitalClinic (Híbrido)",
  "nodes": [
    {
      "name": "Schedule",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.3,
      "position": [100, 300],
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "minutes",
              "minutesInterval": 30
            }
          ]
        }
      }
    },
    {
      "name": "Descargar Inventario FTP",
      "type": "n8n-nodes-base.ftp",
      "typeVersion": 1,
      "position": [300, 300],
      "credentials": {
        "ftp": {
          "id": "VITAL_CLINIC_FTP",
          "name": "[PROD] Vital Clinic - FTP"
        }
      },
      "parameters": {
        "protocol": "ftp",
        "operation": "download",
        "path": "/Existencia/inventario.txt",
        "binaryPropertyName": "data",
        "options": {}
      }
    },
    {
      "name": "Cargar a Debian",
      "type": "n8n-nodes-base.ssh",
      "typeVersion": 1,
      "position": [500, 300],
      "credentials": {
        "sshPassword": {
          "id": "DEBIAN_SSH",
          "name": "[PROD] Debian Webservices - SSH"
        }
      },
      "parameters": {
        "resource": "file",
        "operation": "upload",
        "authentication": "password",
        "path": "/tmp",
        "binaryPropertyName": "data",
        "options": {
          "fileName": "vitalclinic.txt"
        }
      }
    },
    {
      "name": "Ejecutar Python",
      "type": "n8n-nodes-base.ssh",
      "typeVersion": 1,
      "position": [700, 300],
      "credentials": {
        "sshPassword": {
          "id": "DEBIAN_SSH",
          "name": "[PROD] Debian Webservices - SSH"
        }
      },
      "parameters": {
        "resource": "command",
        "operation": "execute",
        "authentication": "password",
        "command": "cat /tmp/vitalclinic.txt \n python3 /opt/scripts/droguerias/generic_inventario.py --proveedor VITALCLINIC --tabla VitalClinic_Inventario",
        "cwd": "/opt/scripts/droguerias"
      }
    }
  ],
  "connections": {
    "Schedule": {
      "main": [
        [
          {
            "node": "Descargar Inventario FTP",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Descargar Inventario FTP": {
      "main": [
        [
          {
            "node": "Cargar a Debian",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Cargar a Debian": {
      "main": [
        [
          {
            "node": "Ejecutar Python",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "saveManualExecutions": true,
    "callerPolicy": "workflowsFromSameOwner",
    "timezone": "America/Caracas"
  },
  "tags": [
    "Producción",
    "Proveedores-Híbridos",
    "FTP",
    "ETL"
  ]
}