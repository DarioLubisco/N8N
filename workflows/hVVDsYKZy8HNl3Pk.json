    {
      "id": "9070f696-160a-4237-aa78-0fa3104cd2ee",
      "name": "Extraer y Preparar",
      "type": "n8n-nodes-base.code",
      "position": [
        1060,
        300
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const reply = $json.choices[0].message.content;\nconst sessionId = $node[\"Preparar Mensajes\"].json.sessionId;\nconst userMsg = $node[\"Preparar Mensajes\"].json.chatInput;\nconst safe = (s) => (s || '').replace(/'/g, \"''\");\nconst insertUser = `INSERT INTO n8n_chat_memory (session_id, role, content) VALUES ('${safe(sessionId)}', 'user', '${safe(userMsg)}')`;\nconst insertAI = `INSERT INTO n8n_chat_memory (session_id, role, content) VALUES ('${safe(sessionId)}', 'assistant', '${safe(reply)}')`;\nreturn [{ json: { output: reply, sessionId, userMessage: userMsg, insertUser, insertAI } }];"
      },
      "typeVersion": 2
    },
