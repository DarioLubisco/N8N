    {
      "id": "f38d5546-4892-4a83-a4be-1831cef84767",
      "name": "Preparar Mensajes",
      "type": "n8n-nodes-base.code",
      "position": [
        580,
        300
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const webhookJson = $node[\"Recibir Mensaje\"].json;\nconst body = webhookJson.body || {};\nconst chatInput = body.chatInput || '';\nconst image = body.image;\nconst audio = body.audio;\nconst sessionId = body.sessionId || ('session_' + Date.now());\n\nlet memory = [];\ntry {\n  const allItems = $input.all();\n  memory = allItems.map(i => i.json).filter(r => r.role && r.content);\n} catch(e) { memory = []; }\n\nlet messages = [{ \n  role: \"system\", \n  content: \"Eres Synapse Portero, el asistente de IA de Farmacia Americana. Puedes procesar imágenes, audio y texto. Responde siempre en español de manera amable y profesional.\" \n}];\nmemory.forEach(r => messages.push({ role: r.role, content: r.content }));\n\nlet userContent = [];\nif (chatInput) userContent.push({ type: \"text\", text: chatInput });\nif (image) userContent.push({ type: \"image_url\", image_url: { url: `data:image/jpeg;base64,${image}` } });\nif (audio) userContent.push({ type: \"input_audio\", input_audio: { data: audio, format: \"webm\" } });\nif (!userContent.length) userContent.push({ type: \"text\", text: \"Hola\" });\n\nmessages.push({ role: \"user\", content: userContent });\nreturn [{ json: { messages, sessionId, chatInput } }];"
      },
      "typeVersion": 2
    },
