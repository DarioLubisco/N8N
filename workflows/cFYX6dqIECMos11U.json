      ],
      "parameters": {
        "query": "INSERT INTO n8n_chat_memory (session_id, role, content) VALUES ('{{$json.sessionId}}', 'user', '{{$json.userMessage.replace(/'/g, \"''\")}}' )",
        "operation": "executeQuery"
      },
      "credentials": {
        "postgres": {
