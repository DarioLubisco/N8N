    },
    {
      "id": "b3e34f68-7c87-4b15-9bf5-cbfbf8122d41",
      "name": "Prepare Messages",
      "type": "n8n-nodes-base.code",
      "position": [
        500,
        300
      ],
      "parameters": {
        "jsCode": "const memory = $items(\"Get Memory\").map(i => i.json);\nconst chatInput = $node[\"Webhook\"].json.body.chatInput;\nconst image = $node[\"Webhook\"].json.body.image;\nconst audio = $node[\"Webhook\"].json.body.audio;\nconst sessionId = $node[\"Webhook\"].json.body.sessionId;\n\nlet messages = [];\nmessages.push({\n    role: \"system\",\n    content: \"You are Synapse Portero. You are a helpful AI assistant connected to Farmacia Americana. You can process images, audio, and text.\"\n});\n\nmemory.forEach(row => {\n    if (row.role && row.content) {\n        messages.push({ role: row.role, content: row.content });\n    }\n});\n\nlet userContent = [];\nuserContent.push({ type: \"text\", text: chatInput });\n\nif (image) {\n    userContent.push({ type: \"image_url\", image_url: { url: `data:image/jpeg;base64,${image}` } });\n}\n\nif (audio) {\n    userContent.push({ type: \"input_audio\", input_audio: { data: audio, format: \"webm\" } });\n}\n\nmessages.push({ role: \"user\", content: userContent });\n\nreturn { messages: messages, sessionId: sessionId, chatInput: chatInput };"
      },
      "typeVersion": 2
    },
    {
      "id": "18f9c12b-3a56-4c9f-ba5c-112dfdcfbc8d",
      "name": "Call OpenRouter",
      "type": "n8n-nodes-base.httpRequest",
      "position": [
        700,
        300
      ],
      "parameters": {
        "url": "https://openrouter.ai/api/v1/chat/completions",
        "method": "POST",
        "options": {},
        "jsonBody": "={\n  \"model\": \"google/gemini-2.0-flash-lite-001\",\n  \"messages\": {{ JSON.stringify($json.messages) }}\n}",
        "sendBody": true,
        "sendHeaders": true,
        "specifyBody": "json",
        "authentication": "predefinedCredentialType",
        "headerParameters": {
          "parameters": [
            {
              "name": "HTTP-Referer",
              "value": "https://farmaciaamericana.es"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "nodeCredentialType": "openRouterApi"
      },
      "credentials": {
        "openRouterApi": {
          "id": "5RBlk4ISiJ3NRiRy",
          "name": "[PROD] OpenRouter - Cuenta Principal"
        }
      },
      "typeVersion": 4.1
    },
    {
      "id": "fc56c80b-db7e-400b-ba85-c54329d91a92",
      "name": "Extract Response",
      "type": "n8n-nodes-base.code",
      "position": [
        900,
        300
      ],
      "parameters": {
        "jsCode": "const assistantReply = $json.choices[0].message.content;\nreturn { \n    output: assistantReply, \n    sessionId: $node[\"Prepare Messages\"].json.sessionId,\n    userMessage: $node[\"Prepare Messages\"].json.chatInput\n};"
      },
      "typeVersion": 2
    },
    {
      "id": "a66fbc4b-f2c3-4d4b-ae84-e4c34a2e88cb",
      "name": "Save User Msg",
      "type": "n8n-nodes-base.postgres",
      "position": [
